# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Drive — pasta principal do catálogo (ex.: CATÁLOGO): cada subpasta = categoria; dentro, M, G, GG com imagens.
# Não use "link público" no Drive: o site exibe as fotos via /api/drive-image (conta de serviço).
# O proxy só aceita IDs já registados na base (produtos ou recibos), para não ler ficheiros aleatórios da conta Google.
# ID na URL: https://drive.google.com/drive/folders/ESTE_ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=
# Opcional: Shared Drive (Unidade compartilhada) — ID da unidade (não o da pasta).
# Se vazio, a API lista em allDrives acessíveis pela conta de serviço.
GOOGLE_DRIVE_SHARED_DRIVE_ID=
# Conta de serviço (escolha UMA opção):
# A) Uma linha: GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# B) Ficheiro: GOOGLE_SERVICE_ACCOUNT_JSON_PATH=C:\caminho\cred.json
#    (ou a variável padrão Google: GOOGLE_APPLICATION_CREDENTIALS)
# C) Base64 do ficheiro inteiro: GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=eyJ0eXBlI...

# Admin: mesma string em todas as chamadas x-admin-key (import Drive + listar/confirmar pedidos).
# Gere um valor longo e aleatório; nunca commite no Git; configure na Vercel como Secret.
ADMIN_API_SECRET=troque-por-um-segredo-longo

# JWT das sessões staff. Se vazio, reutiliza ADMIN_API_SECRET (menos ideal — prefira um segredo só para JWT).
STAFF_JWT_SECRET=

# --- Pedidos públicos (POST /api/orders): limite por IP para reduzir spam (memória por instância).
# Predefinição: 30 pedidos / 15 min / IP (ajuste se partilharem Wi‑Fi legítimo).
ORDER_RATE_LIMIT_MAX=30
ORDER_RATE_LIMIT_WINDOW_MS=900000

# --- Login staff: tentativas por IP / janela (força bruta).
STAFF_LOGIN_RATE_LIMIT_MAX=25
STAFF_LOGIN_RATE_LIMIT_WINDOW_MS=900000

# Bootstrap da equipa (POST /api/auth/staff/bootstrap): em produção fica DESATIVADO por defeito.
# Defina temporariamente ALLOW_STAFF_BOOTSTRAP=1 só para criar contas iniciais; depois remova.
ALLOW_STAFF_BOOTSTRAP=

# WhatsApp do vendedor (somente dígitos, ex.: 5511999999999)
NEXT_PUBLIC_WHATSAPP_SELLER_NUMBER=

# Estoque inicial ao importar imagens MARCA COR (sem número no ficheiro). Depois o stock só muda na app.
DEFAULT_INITIAL_STOCK=1

# --- Modo simples (OAuth): cole link da pasta em /admin/configuracao + "Conectar Google"
# Google Cloud → Credenciais → ID do cliente OAuth → tipo "Aplicação Web"
# URIs de redirecionamento autorizados: https://SEU_DOMINIO/api/auth/google/callback
# Em dev: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# URL pública do site (para o redirect OAuth). Dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Opcional: URL canónica para links no WhatsApp (recibo). Em dev no telemóvel use http://SEU_IP_LAN:3000
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Job diário Vercel Cron: GET /api/cron/daily-catalog-sync
# Gere um segredo longo; em Vercel o mesmo valor em Environment Variables.
# Teste local: curl -H "Authorization: Bearer SEU_CRON_SECRET" http://localhost:3000/api/cron/daily-catalog-sync
CRON_SECRET=
